{
  "manifest_version": 3,
  "name": "Gradescope DueDates Planner",
  "description": "A Gradescope side-panel planner with synced Todo and Calendar views, smart refresh, and automatic opening on Gradescope tabs.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.gradescope.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Open Gradescope DueDates Planner"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.gradescope.com/*"
      ],
      "js": [
        "content-scripts/gradescope.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
